# Copy to .env in the project root and fill in values.
# Required for api-server local development.

DATABASE_URL=postgresql://user:password@localhost:5432/nazdikam
SESSION_SECRET=change-me-to-a-long-random-string

# API server port (default 8080)
PORT=8080

# Temporary until SMS is connected: return OTP in API response as _dev_otp
# EXPOSE_DEV_OTP=true

# Set false for HTTP (no HTTPS) so session cookie works
# COOKIE_SECURE=false

# Web dev server (used when running artifacts/web)
# PORT=22333
BASE_PATH=/
# API_PROXY_TARGET=http://localhost:8080
